# Supabase Configuration
# Get these values from your Supabase project dashboard:
# https://supabase.com/dashboard/project/[your-project-id]/settings/api

NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# LLM Configuration (Anthropic Claude)
# ===========================================

# Anthropic API Key (required for AI features)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Model (optional - defaults to claude-3-haiku-20240307)
# Options: claude-3-haiku-20240307, claude-3-5-sonnet-20241022
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# ===========================================
# Stripe Configuration (optional)
# ===========================================
# Required for billing features. Get from Stripe Dashboard.
# App runs without these, but subscription features disabled.

# API Keys: Stripe Dashboard → Developers → API keys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook Secret: Stripe Dashboard → Developers → Webhooks → Signing secret
# Create endpoint pointing to https://[your-domain]/api/webhooks/stripe
# STRIPE_WEBHOOK_SECRET=whsec_...

# Price ID: Stripe Dashboard → Products → [Your Product] → Price ID
# Create a $15/month recurring price for TimeLi subscription
# STRIPE_PRICE_ID=price_...

# ===========================================
# Usage Limits
# ===========================================
# Monthly limits per user (defaults shown)
# USAGE_LIMIT_GENERATIONS=200
# USAGE_LIMIT_RECALIBRATIONS=500
