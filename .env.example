# Supabase Configuration
# Get these values from your Supabase project dashboard:
# https://supabase.com/dashboard/project/[your-project-id]/settings/api

NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# LLM Configuration
# ===========================================

# Self-hosted vLLM (primary when GPU is on)
# Leave empty to disable self-hosted LLM
# LLM_BASE_URL=https://your-vllm-instance.runpod.io/v1
# LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Schedule: When GPU is available (24h format, comma-separate multiple windows)
# LLM_SCHEDULE=09:00-14:00
# LLM_SCHEDULE=09:00-14:00,18:00-22:00  # Multiple windows
# LLM_TIMEZONE=America/New_York         # Default timezone

# OpenAI API fallback (when self-hosted is unavailable)
# Used when outside schedule window or GPU is offline
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini  # Default model

# API rate limit per user per day (default: 10)
# Set high for testing, lower for production
# API_DAILY_LIMIT=10
# API_DAILY_LIMIT=1000  # For testing

# ===========================================
# Stripe Configuration (optional)
# ===========================================
# Required for billing features. Get from Stripe Dashboard.
# App runs without these, but subscription features disabled.

# API Keys: Stripe Dashboard → Developers → API keys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook Secret: Stripe Dashboard → Developers → Webhooks → Signing secret
# Create endpoint pointing to https://[your-domain]/api/webhooks/stripe
# STRIPE_WEBHOOK_SECRET=whsec_...

# Price ID: Stripe Dashboard → Products → [Your Product] → Price ID
# Create a $15/month recurring price for TimeLi subscription
# STRIPE_PRICE_ID=price_...

# ===========================================
# Usage Limits
# ===========================================
# Monthly limits per user (defaults shown)
# USAGE_LIMIT_GENERATIONS=200
# USAGE_LIMIT_RECALIBRATIONS=500
